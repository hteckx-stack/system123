{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "position": {
          "type": "string",
          "description": "The user's position in the company."
        },
        "department": {
          "type": "string",
          "description": "The department the user belongs to."
        },
        "photoUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL for the user's profile picture."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ],
          "description": "The user's status."
        }
      },
      "required": [
        "name",
        "email",
        "status",
        "position",
        "department",
        "phone"
      ]
    },
    "Document": {
      "title": "Document",
      "description": "Represents a document uploaded or generated for a staff member.",
      "type": "object",
      "properties": {
        "staffName": {
          "type": "string",
          "description": "Name of the staff member the document belongs to."
        },
        "staffId": {
          "type": "string",
          "description": "ID of the staff member."
        },
        "type": {
          "type": "string",
          "description": "Type of the document (e.g., Contract, Payslip)."
        },
        "fileName": {
          "type": "string",
          "description": "The name of the document file."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the document was created/uploaded."
        }
      },
      "required": [
        "staffName",
        "staffId",
        "type",
        "fileName",
        "date"
      ]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Represents an announcement sent to staff members.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the announcement."
        },
        "message": {
          "type": "string",
          "description": "The content of the announcement."
        },
        "recipientIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "An array of staff user IDs who received the announcement."
        },
        "recipientCount": {
          "type": "number",
          "description": "The number of recipients."
        },
        "sentAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the announcement was sent."
        }
      },
      "required": [
        "title",
        "message",
        "recipientIds",
        "recipientCount",
        "sentAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information, keyed by user ID."
    },
    "/documents/{documentId}": {
      "schema": {
        "$ref": "#/entities/Document"
      },
      "description": "Stores documents associated with staff members."
    },
    "/announcements/{announcementId}": {
      "schema": {
        "$ref": "#/entities/Announcement"
      },
      "description": "Stores all announcements sent to staff."
    }
  }
}
