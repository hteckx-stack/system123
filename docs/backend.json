
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "status": { "type": "string", "enum": ["pending", "active", "inactive"] }
      },
      "required": ["name", "email", "status", "role"]
    },
    "LoginRequest": {
      "title": "Login Request",
      "description": "A request from a device to log in a staff member.",
      "type": "object",
      "properties": {
        "staffName": { "type": "string" },
        "staffId": { "type": "string" },
        "deviceModel": { "type": "string" },
        "deviceId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["staffName", "staffId", "deviceModel", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to a staff member.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "staff_id": { "type": "string" },
        "staff_name": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "staff_id", "status", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "Represents a document uploaded or generated for a staff member.",
      "type": "object",
      "properties": {
        "staffName": { "type": "string" },
        "staffId": { "type": "string" },
        "type": { "type": "string" },
        "fileName": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["staffName", "staffId", "type", "fileName", "date"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Represents an announcement sent to staff members.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "recipientIds": { "type": "array", "items": { "type": "string" } },
        "recipientCount": { "type": "number" },
        "sentAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "sentAt"]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Represents a staff member's request for leave.",
      "type": "object",
      "properties": {
        "staff_id": { "type": "string" },
        "name": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["staff_id", "name", "start_date", "end_date", "reason", "type", "status", "created_at"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation between an admin and a staff member.",
      "type": "object",
      "properties": {
        "staff_id": { "type": "string" },
        "staff_name": { "type": "string" },
        "topic": { "type": "string", "enum": ["Contract", "Payslip", "Leave", "Announcement", "General"] },
        "last_message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["staff_id", "staff_name", "topic", "last_message", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a conversation.",
      "type": "object",
      "properties": {
        "conversation_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "sender_role": { "type": "string", "enum": ["admin", "staff"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["conversation_id", "sender_id", "sender_role", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/login_requests/{requestId}": {
      "schema": { "$ref": "#/entities/LoginRequest" },
      "description": "Stores security login requests."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores assigned tasks."
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Stores documents."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Stores announcement history."
    },
    "/leave_requests/{requestId}": {
      "schema": { "$ref": "#/entities/LeaveRequest" },
      "description": "Stores leave applications."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Stores chat metadata."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores individual messages."
    }
  }
}
