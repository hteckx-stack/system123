
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "position": {
          "type": "string",
          "description": "The user's position in the company."
        },
        "department": {
          "type": "string",
          "description": "The department the user belongs to."
        },
        "photoUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL for the user's profile picture."
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "inactive"
          ],
          "description": "The user's status."
        }
      },
      "required": [
        "name",
        "email",
        "status"
      ]
    },
    "Document": {
      "title": "Document",
      "description": "Represents a document uploaded or generated for a staff member.",
      "type": "object",
      "properties": {
        "staffName": {
          "type": "string",
          "description": "Name of the staff member the document belongs to."
        },
        "staffId": {
          "type": "string",
          "description": "ID of the staff member."
        },
        "type": {
          "type": "string",
          "description": "Type of the document (e.g., Contract, Payslip)."
        },
        "fileName": {
          "type": "string",
          "description": "The name of the document file."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date the document was created/uploaded."
        }
      },
      "required": [
        "staffName",
        "staffId",
        "type",
        "fileName",
        "date"
      ]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Represents an announcement sent to staff members.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the announcement."
        },
        "message": {
          "type": "string",
          "description": "The content of the announcement."
        },
        "recipientIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "An array of staff user IDs who received the announcement."
        },
        "recipientCount": {
          "type": "number",
          "description": "The number of recipients."
        },
        "sentAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the announcement was sent."
        }
      },
      "required": [
        "title",
        "message",
        "recipientIds",
        "recipientCount",
        "sentAt"
      ]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Represents a staff member's request for leave.",
      "type": "object",
      "properties": {
        "staff_id": { "type": "string" },
        "name": { "type": "string" },
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["staff_id", "name", "start_date", "end_date", "reason", "type", "status", "created_at"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation between an admin and a staff member.",
      "type": "object",
      "properties": {
        "staff_id": { "type": "string" },
        "staff_name": { "type": "string" },
        "topic": { "type": "string", "enum": ["Contract", "Payslip", "Leave", "Announcement", "General"] },
        "last_message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["staff_id", "staff_name", "topic", "last_message", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a conversation.",
      "type": "object",
      "properties": {
        "conversation_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "sender_role": { "type": "string", "enum": ["admin", "staff"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["conversation_id", "sender_id", "sender_role", "message", "timestamp"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "A log of important system actions.",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "details": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "details", "user_id", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/documents/{documentId}": {
      "schema": {
        "$ref": "#/entities/Document"
      },
      "description": "Stores documents associated with staff members."
    },
    "/announcements/{announcementId}": {
      "schema": {
        "$ref": "#/entities/Announcement"
      },
      "description": "Stores all announcements sent to staff."
    },
    "/leave_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/LeaveRequest"
      },
      "description": "Stores leave requests."
    },
    "/conversations/{conversationId}": {
      "schema": {
        "$ref": "#/entities/Conversation"
      },
      "description": "Stores conversation metadata."
    },
    "/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Stores chat messages."
    },
    "/activity_logs/{logId}": {
      "schema": {
        "$ref": "#/entities/ActivityLog"
      },
      "description": "Stores audit logs."
    }
  }
}
